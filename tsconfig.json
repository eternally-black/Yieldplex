{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "lib": ["es2020"],
    "types": ["node", "mocha", "chai"]
  },
  "include": ["tests/**/*.ts", "ts/**/*.ts", "scripts/**/*.ts"]
}
