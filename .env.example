# Copy to .env and fill in. A real mainnet RPC is required so surfnet can JIT-fetch
# protocol state and so verify-addresses can read on-chain accounts.
# Use a private endpoint (Helius / QuickNode / Triton / Alchemy) — public mainnet-beta is rate-limited.
MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
